# Rate-Limit Test Kit — optional configuration template.
# Copy to `.env` and adjust. This kit needs NO secret and NO account; these are
# convenience defaults only. NEVER commit real infrastructure values.

# The base URL of the endpoint you want to test (the kit reads --url on the
# command line — this is just a note-to-self).
RLTK_URL=http://localhost:8000

# Your per-window request budget — pass to the harness as --limit. If you don't
# know it, the kit reads it from a RateLimit-Limit header when your endpoint
# sends one.
RLTK_LIMIT=5

# The reset-wait fallback (seconds) used by window-reset when there's no
# Retry-After to read — pass as --window.
RLTK_WINDOW=1

# Seconds to sleep before each burst so it starts in a fresh window, for a real
# endpoint without a /_debug/reset route — pass as --settle. Set to your window
# length.
RLTK_SETTLE=0

# --- bundled reference stub knobs (stub_handler.py only) ---------------------
# Requests allowed per window in the CORRECT reference limiter.
RLTK_STUB_LIMIT=5
# Window length (ms) for the reference limiter — short keeps the reset test fast.
RLTK_WINDOW_MS=1000
# Which header names the reference limiter emits: ratelimit | legacy | both.
RLTK_HEADER_STYLE=both
