# Slack Webhook Test Kit — environment template.
# Copy to `.env` and fill in your real value. NEVER commit a real secret.
# The kit reads the NAME of this variable from the environment and never
# stores, logs, or echoes the value.

# Your Slack app's SIGNING SECRET.
#   Slack app -> Basic Information -> App Credentials -> Signing Secret.
#   This is NOT a bot/user OAuth token (xoxb-/xoxp-) and NOT the legacy
#   Verification Token. It is the secret Slack uses to sign X-Slack-Signature.
SLACK_SIGNING_SECRET=replace-with-your-signing-secret
