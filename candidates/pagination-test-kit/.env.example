# Pagination Test Kit — optional configuration template.
# Copy to `.env` and adjust. This kit needs NO secret and NO account; these are
# convenience defaults only. NEVER commit real infrastructure values.

# The base URL of the endpoint you want to test (the kit reads --url on the
# command line — this is just a note-to-self).
PGTK_URL=http://localhost:8000

# The page size to traverse with — pass to the harness as --limit. Use a small
# value so the dataset spans several pages.
PGTK_LIMIT=3

# Your documented maximum page size — pass as --max. Used by the page-size check
# when your endpoint sends no X-Page-Size-Max header.
PGTK_MAX=5

# Which fixture (request/response template) to use — pass as --fixture. Defaults
# to items_keyset (matches the bundled stubs). items_pagetoken is a differently-
# named cursor API template to adapt to your own endpoint.
PGTK_FIXTURE=items_keyset

# --- bundled reference stub knobs (stub_handler.py only) ---------------------
# Documented maximum page size the CORRECT reference pager clamps to.
PGTK_STUB_MAX=5
# HMAC key the correct stub signs its opaque cursor with. The default is a
# clearly-labelled NON-secret used only so the demo cursor is tamper-evident;
# a real deployment would use a real secret from its own secret store.
PGTK_SECRET=pgtk-demo-cursor-key-not-a-secret
