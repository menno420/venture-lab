# Idempotency Key Test Kit — optional configuration template.
# Copy to `.env` and adjust. This kit needs NO secret and NO account; these are
# convenience defaults only. NEVER commit real infrastructure values.

# The base URL of the endpoint you want to test (used in the commands you run;
# the kit reads --url on the command line — this is just a note-to-self).
IKT_URL=http://localhost:8000

# Your DOCUMENTED policy for a request that arrives with NO Idempotency-Key:
#   required     -> a keyless request must be rejected (4xx)
#   passthrough  -> a keyless request is processed without idempotency (2xx)
# Pass this to the harness as --missing-key-mode.
IKT_MISSING_KEY_MODE=required

# --- bundled reference stub knobs (stub_handler.py only) ---------------------
# Whether the CORRECT reference stub requires the Idempotency-Key header.
#   1 (default) -> missing key is 400 ; 0 -> pass-through (process without it)
IKT_REQUIRE_KEY=1
# Simulated work (milliseconds) inside the reference stub's side effect, so the
# concurrency scenario's two in-flight requests genuinely overlap. 0 = none.
IKT_EXEC_DELAY_MS=0
