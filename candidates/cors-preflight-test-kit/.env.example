# CORS Preflight Test Kit — optional configuration template.
# Copy to `.env` and adjust. This kit needs NO secret and NO account; these are
# convenience defaults only. NEVER commit real infrastructure values.

# The base URL of the endpoint you want to test (the kit reads --url on the
# command line — this is just a note-to-self).
CPTK_URL=http://localhost:8000

# The browser origin your front-end is served from — pass to the harness as
# --origin. This is the Origin the kit sends; it must be an origin your server
# is supposed to allow.
CPTK_ORIGIN=https://app.example.com

# A disallowed probe origin the reflect-guard check sends — pass as --bad-origin.
# It must be an origin your server should REJECT (the check fails if the server
# echoes it back into Access-Control-Allow-Origin).
CPTK_BAD_ORIGIN=https://cptk-probe.invalid

# --- bundled reference stub knob (stub_handler.py only) ----------------------
# Comma-separated allowlist the CORRECT reference endpoint accepts.
CPTK_ALLOWED_ORIGINS=https://app.example.com
