# Membership-Site Boilerplate Kit — environment template.
# Copy to `.env` and fill in your OWN keys. Never commit real secrets.
# With these UNSET the server runs in mock mode (zero accounts needed).

# Stripe — Developers -> API keys. Start with the sk_test_ key.
STRIPE_SECRET_KEY=sk_test_...        # owner: paste your Stripe TEST secret key here
STRIPE_WEBHOOK_SECRET=whsec_...      # owner: paste your Stripe webhook signing secret here

# Discord — Server Settings -> Invites (or a bot token for auto-mint).
DISCORD_INVITE_URL=                  # owner: paste your Discord invite URL here

# Supabase — Project Settings -> API (auth + persistent user store).
SUPABASE_URL=                        # owner: paste your Supabase project URL here
SUPABASE_KEY=                        # owner: paste your Supabase anon/service key here
