# JWT Auth Test Kit — optional configuration template.
# Copy to `.env` and adjust. This kit needs NO account; these are convenience
# defaults only. NEVER commit a real signing secret or private key.

# The base URL of the endpoint you want to test (the kit reads --url on the
# command line — this is just a note-to-self).
JATK_URL=http://localhost:8000

# Your server's HS256 signing secret — pass to the harness as --secret. The kit
# needs it to mint a valid token AND otherwise-valid attack tokens (an expired
# token must carry a real signature so only the exp check rejects it).
# PLACEHOLDER ONLY — put your real secret in your own secret store, not here.
JATK_SECRET=replace-with-your-hs256-secret

# The audience / issuer your server enforces — pass as --aud / --iss. Leave empty
# to disable (the audience-enforced / issuer-enforced properties then SKIP).
JATK_AUD=jatk-demo-api
JATK_ISS=jatk-demo-issuer

# Path to the RSA/EC public-key blob used to craft the algorithm-confusion token —
# pass as --pubkey. Defaults to the bundled fixtures/test_public_key.pem. Point it
# at the public key your service also trusts to make the confusion test faithful.
JATK_PUBKEY_FILE=fixtures/test_public_key.pem

# --- bundled reference stub knobs (stub_handler.py only) ---------------------
# The demo secret the CORRECT reference verifier checks HS256 signatures with. The
# default is a clearly-labelled NON-secret used only so the demo runs; a real
# deployment would use a real secret from its own secret store.
JATK_STUB_SECRET=jatk-demo-hs256-secret-not-a-real-secret
# The audience / issuer the correct reference verifier enforces (empty disables).
JATK_STUB_AUD=jatk-demo-api
JATK_STUB_ISS=jatk-demo-issuer
